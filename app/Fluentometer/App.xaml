<Application
    x:Class="Fluentometer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Fluentometer.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 control styles and ThemeResource/StaticResource brushes -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- GaugeControl default style -->
                <ResourceDictionary Source="Controls/GaugeControl.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Shared converters — declared here so they're accessible from any page
                via {StaticResource BoolToVisibility}. BoolToVisibilityConverter is a
                project-local class (Converters/BoolToVisibilityConverter.cs) because
                WinUI 3 does not ship a built-in BooleanToVisibilityConverter the way
                UWP did — it must be declared with the project namespace.
            -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
